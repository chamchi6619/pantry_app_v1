# EAS Build ignore — keeps upload under 50MB
# Based on .gitignore + extra dev/test artifacts

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native (generated by prebuild)
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android

# Dev/test assets not needed in production bundle
assets/footer_native_testing_*.png
assets/footer_native_ad_ex*.png

# Git
.git/

# Documentation
*.md
LICENSE
